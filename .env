# Environment variables for the P2P Shopping Frontend
# Documentation: 
# - .env: Shared defaults (placeholders)
# - .env.development: Development overrides
# - .env.local: Local overrides (git-ignored)
# Use .env.development.local for your local machine's specific IP if not using localhost.

# The API base URL. Use '/' to rely on the Vite proxy in development.
VITE_API_BASE_URL=/

# The WebSocket URL. Use '/ws' to rely on the Vite proxy in development.
VITE_SOCKET_URL=/ws
